// Prisma schema for Pyrodactyl panel — generated from Eloquent models and migrations
// All table/column names use @@map/@map to match the existing Laravel snake_case database schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── User ───────────────────────────────────────────────────────────────────

model User {
  id                  Int       @id @default(autoincrement())
  externalId          String?   @unique @map("external_id")
  uuid                String    @unique
  username            String    @unique
  email               String    @unique
  nameFirst           String?   @map("name_first")
  nameLast            String?   @map("name_last")
  password            String   
  rememberToken       String?   @map("remember_token")
  language            String    @default("en")
  rootAdmin           Boolean   @default(false) @map("root_admin")
  useTotp             Boolean   @default(false) @map("use_totp")
  totpSecret          String?   @map("totp_secret")
  totpAuthenticatedAt DateTime? @map("totp_authenticated_at")
  gravatar            Boolean   @default(false)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  servers          Server[]
  apiKeys          ApiKey[]
  recoveryTokens   RecoveryToken[]
  sshKeys          UserSSHKey[]
  subusers         Subuser[]
  auditLogs        AuditLog[]
  elytraJobs       ElytraJob[]
  serverOperations ServerOperation[]

  @@map("users")
}

// ─── Server ─────────────────────────────────────────────────────────────────

model Server {
  id                             Int       @id @default(autoincrement())
  externalId                     String?   @unique @map("external_id")
  uuid                           String    @unique
  uuidShort                      String    @unique @map("uuidShort")
  nodeId                         Int       @map("node_id")
  name                           String   
  description                    String    @default("")
  status                         String?  
  skipScripts                    Boolean   @default(false) @map("skip_scripts")
  ownerId                        Int       @map("owner_id")
  memory                         Int       @default(0)
  overheadMemory                 Int       @default(0) @map("overhead_memory")
  swap                           Int       @default(0)
  disk                           Int       @default(0)
  io                             Int       @default(500)
  cpu                            Int       @default(0)
  threads                        String?  
  oomDisabled                    Boolean   @default(true) @map("oom_disabled")
  excludeFromResourceCalculation Boolean   @default(false) @map("exclude_from_resource_calculation")
  allocationId                   Int       @unique @map("allocation_id")
  nestId                         Int       @map("nest_id")
  eggId                          Int       @map("egg_id")
  startup                        String   
  image                          String   
  allocationLimit                Int?      @map("allocation_limit")
  databaseLimit                  Int?      @map("database_limit")
  backupLimit                    Int?      @map("backup_limit")
  backupStorageLimit             Int?      @map("backup_storage_limit")
  installedAt                    DateTime? @map("installed_at")
  createdAt                      DateTime  @default(now()) @map("created_at")
  updatedAt                      DateTime  @updatedAt @map("updated_at")

  user       User       @relation(fields: [ownerId], references: [id])
  node       Node       @relation(fields: [nodeId], references: [id])
  nest       Nest       @relation(fields: [nestId], references: [id])
  egg        Egg        @relation(fields: [eggId], references: [id])
  allocation Allocation @relation("ServerPrimaryAllocation", fields: [allocationId], references: [id])

  allocations      Allocation[]      @relation("ServerAllocations")
  databases        Database[]
  schedules        Schedule[]
  backups          Backup[]
  subusers         Subuser[]
  serverVariables  ServerVariable[]
  mountServers     MountServer[]
  subdomains       ServerSubdomain[]
  transfers        ServerTransfer[]
  auditLogs        AuditLog[]
  elytraJobs       ElytraJob[]
  serverOperations ServerOperation[]

  @@index([nodeId], map: "servers_node_id_foreign")
  @@index([ownerId], map: "servers_owner_id_foreign")
  @@index([nestId], map: "servers_nest_id_foreign")
  @@index([eggId], map: "servers_egg_id_foreign")
  @@map("servers")
}

// ─── Node ───────────────────────────────────────────────────────────────────

model Node {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique
  public             Boolean  @default(true) @map("public")
  trustAlias         Boolean  @default(false) @map("trust_alias")
  name               String  
  description        String? 
  locationId         Int      @map("location_id")
  fqdn               String  
  internalFqdn       String?  @map("internal_fqdn")
  useSeparateFqdns   Boolean  @default(false) @map("use_separate_fqdns")
  scheme             String   @default("https")
  behindProxy        Boolean  @default(false) @map("behind_proxy")
  maintenanceMode    Boolean  @default(false) @map("maintenance_mode")
  memory             Int     
  memoryOverallocate Int      @default(0) @map("memory_overallocate")
  disk               Int     
  diskOverallocate   Int      @default(0) @map("disk_overallocate")
  uploadSize         Int      @default(100) @map("upload_size")
  daemonTokenId      String   @unique @map("daemon_token_id")
  daemonToken        String   @map("daemon_token")
  daemonListen       Int      @default(8080) @map("daemonListen")
  daemonSFTP         Int      @default(2022) @map("daemonSFTP")
  daemonBase         String   @default("/var/lib/pterodactyl/volumes") @map("daemonBase")
  daemonType         String   @default("elytra") @map("daemonType")
  backupDisk         String   @default("wings") @map("backupDisk")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  location      Location       @relation(fields: [locationId], references: [id])
  servers       Server[]
  allocations   Allocation[]
  mountNodes    MountNode[]
  databaseHosts DatabaseHost[]

  @@index([locationId], map: "nodes_location_id_foreign")
  @@map("nodes")
}

// ─── Allocation ─────────────────────────────────────────────────────────────

model Allocation {
  id        Int      @id @default(autoincrement())
  nodeId    Int      @map("node_id")
  ip        String  
  ipAlias   String?  @map("ip_alias")
  port      Int     
  serverId  Int?     @map("server_id")
  notes     String? 
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  node             Node    @relation(fields: [nodeId], references: [id])
  server           Server? @relation("ServerAllocations", fields: [serverId], references: [id])
  primaryForServer Server? @relation("ServerPrimaryAllocation")

  @@index([nodeId], map: "allocations_node_id_foreign")
  @@index([serverId], map: "allocations_server_id_foreign")
  @@map("allocations")
}

// ─── Location ───────────────────────────────────────────────────────────────

model Location {
  id        Int      @id @default(autoincrement())
  short     String   @unique
  long      String? 
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  nodes Node[]

  @@map("locations")
}

// ─── Nest ───────────────────────────────────────────────────────────────────

model Nest {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique
  author      String  
  name        String  
  description String? 
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  eggs    Egg[]
  servers Server[]

  @@map("nests")
}

// ─── Egg ────────────────────────────────────────────────────────────────────

model Egg {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique
  nestId             Int      @map("nest_id")
  author             String  
  name               String  
  description        String? 
  features           Json?
  dockerImages       Json     @map("docker_images")
  fileDenylist       Json?    @map("file_denylist")
  updateUrl          String?  @map("update_url")
  forceOutgoingIp    Boolean  @default(false) @map("force_outgoing_ip")
  startup            String? 
  configFrom         Int?     @map("config_from")
  configStop         String?  @map("config_stop")
  configLogs         String?  @map("config_logs")
  configStartup      String?  @map("config_startup")
  configFiles        String?  @map("config_files")
  copyScriptFrom     Int?     @map("copy_script_from")
  scriptContainer    String   @default("alpine:3.4") @map("script_container")
  scriptEntry        String   @default("ash") @map("script_entry")
  scriptInstall      String?  @map("script_install")
  scriptIsPrivileged Boolean  @default(true) @map("script_is_privileged")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  nest          Nest  @relation(fields: [nestId], references: [id])
  configFromEgg Egg?  @relation("EggConfigInheritance", fields: [configFrom], references: [id])
  configToEggs  Egg[] @relation("EggConfigInheritance")
  scriptFromEgg Egg?  @relation("EggScriptInheritance", fields: [copyScriptFrom], references: [id])
  scriptToEggs  Egg[] @relation("EggScriptInheritance")

  servers   Server[]
  variables EggVariable[]
  eggMounts EggMount[]

  @@index([nestId], map: "eggs_nest_id_foreign")
  @@index([configFrom], map: "eggs_config_from_foreign")
  @@index([copyScriptFrom], map: "eggs_copy_script_from_foreign")
  @@map("eggs")
}

// ─── EggVariable ────────────────────────────────────────────────────────────

model EggVariable {
  id           Int      @id @default(autoincrement())
  eggId        Int      @map("egg_id")
  name         String  
  description  String   @default("")
  envVariable  String   @map("env_variable")
  defaultValue String   @default("") @map("default_value")
  userViewable Boolean  @default(false) @map("user_viewable")
  userEditable Boolean  @default(false) @map("user_editable")
  rules        String  
  sort         Int?    
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  egg             Egg              @relation(fields: [eggId], references: [id])
  serverVariables ServerVariable[]

  @@index([eggId], map: "egg_variables_egg_id_foreign")
  @@map("egg_variables")
}

// ─── ServerVariable ─────────────────────────────────────────────────────────

model ServerVariable {
  id            Int      @id @default(autoincrement())
  serverId      Int      @map("server_id")
  variableId    Int      @map("variable_id")
  variableValue String   @default("") @map("variable_value")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  server   Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  variable EggVariable @relation(fields: [variableId], references: [id])

  @@unique([serverId, variableId])
  @@index([serverId], map: "server_variables_server_id_foreign")
  @@index([variableId], map: "server_variables_variable_id_foreign")
  @@map("server_variables")
}

// ─── Schedule ───────────────────────────────────────────────────────────────

model Schedule {
  id             Int       @id @default(autoincrement())
  serverId       Int       @map("server_id")
  name           String?  
  cronDayOfWeek  String    @default("*") @map("cron_day_of_week")
  cronMonth      String    @default("*") @map("cron_month")
  cronDayOfMonth String    @default("*") @map("cron_day_of_month")
  cronHour       String    @default("*") @map("cron_hour")
  cronMinute     String    @default("*") @map("cron_minute")
  isActive       Boolean   @default(true) @map("is_active")
  isProcessing   Boolean   @default(false) @map("is_processing")
  onlyWhenOnline Boolean   @default(false) @map("only_when_online")
  lastRunAt      DateTime? @map("last_run_at")
  nextRunAt      DateTime? @map("next_run_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@index([serverId], map: "schedules_server_id_foreign")
  @@map("schedules")
}

// ─── Task ───────────────────────────────────────────────────────────────────

model Task {
  id                Int      @id @default(autoincrement())
  scheduleId        Int      @map("schedule_id")
  sequenceId        Int      @map("sequence_id")
  action            String  
  payload           String   @default("")
  timeOffset        Int      @default(0) @map("time_offset")
  isQueued          Boolean  @default(false) @map("is_queued")
  isProcessing      Boolean  @default(false) @map("is_processing")
  continueOnFailure Boolean  @default(false) @map("continue_on_failure")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId], map: "tasks_schedule_id_foreign")
  @@map("tasks")
}

// ─── Database (server databases) ────────────────────────────────────────────

model Database {
  id             Int      @id @default(autoincrement())
  serverId       Int      @map("server_id")
  databaseHostId Int      @map("database_host_id")
  database       String  
  username       String  
  remote         String   @default("%")
  password       String  
  maxConnections Int?     @default(0) @map("max_connections")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  server Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  host   DatabaseHost @relation(fields: [databaseHostId], references: [id])

  @@index([serverId], map: "databases_server_id_foreign")
  @@index([databaseHostId], map: "databases_database_host_id_foreign")
  @@map("databases")
}

// ─── DatabaseHost ───────────────────────────────────────────────────────────

model DatabaseHost {
  id           Int      @id @default(autoincrement())
  name         String  
  host         String  
  port         Int      @default(3306)
  username     String  
  password     String  
  maxDatabases Int?     @map("max_databases")
  nodeId       Int?     @map("node_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  node      Node?      @relation(fields: [nodeId], references: [id])
  databases Database[]

  @@index([nodeId], map: "database_hosts_node_id_foreign")
  @@map("database_hosts")
}

// ─── Subuser ────────────────────────────────────────────────────────────────

model Subuser {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  serverId    Int      @map("server_id")
  permissions Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
  @@index([serverId], map: "subusers_server_id_foreign")
  @@map("subusers")
}

// ─── Backup ─────────────────────────────────────────────────────────────────

model Backup {
  id           Int       @id @default(autoincrement())
  serverId     Int       @map("server_id")
  uuid         String    @unique
  isSuccessful Boolean   @default(false) @map("is_successful")
  isLocked     Boolean   @default(false) @map("is_locked")
  isAutomatic  Boolean   @default(false) @map("is_automatic")
  name         String   
  ignoredFiles Json      @map("ignored_files")
  serverState  Json?     @map("server_state")
  disk         String   
  checksum     String?  
  bytes        BigInt    @default(0)
  uploadId     String?   @map("upload_id")
  snapshotId   String?   @map("snapshot_id")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId], map: "backups_server_id_foreign")
  @@map("backups")
}

// ─── ServerTransfer ─────────────────────────────────────────────────────────

model ServerTransfer {
  id                       Int      @id @default(autoincrement())
  serverId                 Int      @map("server_id")
  successful               Boolean?
  archived                 Boolean  @default(false)
  oldNode                  Int      @map("old_node")
  newNode                  Int      @map("new_node")
  oldAllocation            Int      @map("old_allocation")
  newAllocation            Int      @map("new_allocation")
  oldAdditionalAllocations Json?    @map("old_additional_allocations")
  newAdditionalAllocations Json?    @map("new_additional_allocations")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId], map: "server_transfers_server_id_foreign")
  @@map("server_transfers")
}

// ─── ActivityLog ────────────────────────────────────────────────────────────

model ActivityLog {
  id          BigInt   @id @default(autoincrement())
  batch       String? 
  event       String  
  ip          String  
  description String? 
  actorType   String?  @map("actor_type")
  actorId     BigInt?  @map("actor_id")
  apiKeyId    Int?     @map("api_key_id")
  properties  Json?
  timestamp   DateTime @default(now())

  subjects ActivityLogSubject[]

  @@index([event], map: "activity_logs_event_index")
  @@index([actorType, actorId], map: "activity_logs_actor_type_actor_id_index")
  @@map("activity_logs")
}

// ─── ActivityLogSubject ─────────────────────────────────────────────────────

model ActivityLogSubject {
  id            BigInt @id @default(autoincrement())
  activityLogId BigInt @map("activity_log_id")
  subjectType   String @map("subject_type")
  subjectId     BigInt @map("subject_id")

  activityLog ActivityLog @relation(fields: [activityLogId], references: [id], onDelete: Cascade)

  @@index([activityLogId], map: "activity_log_subjects_activity_log_id_foreign")
  @@index([subjectType, subjectId], map: "activity_log_subjects_subject_type_subject_id_index")
  @@map("activity_log_subjects")
}

// ─── AuditLog (deprecated — use ActivityLog) ────────────────────────────────

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  uuid      String   @unique
  userId    Int?     @map("user_id")
  serverId  Int?     @map("server_id")
  action    String  
  subaction String? 
  device    Json
  metadata  Json
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  server Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([userId], map: "audit_logs_user_id_foreign")
  @@index([serverId], map: "audit_logs_server_id_foreign")
  @@index([action])
  @@map("audit_logs")
}

// ─── ApiKey ─────────────────────────────────────────────────────────────────

model ApiKey {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  keyType          Int       @default(0) @map("key_type")
  identifier       String    @unique
  token            String   
  allowedIps       Json?     @map("allowed_ips")
  memo             String?  
  lastUsedAt       DateTime? @map("last_used_at")
  expiresAt        DateTime? @map("expires_at")
  rServers         Int       @default(0) @map("r_servers")
  rNodes           Int       @default(0) @map("r_nodes")
  rAllocations     Int       @default(0) @map("r_allocations")
  rUsers           Int       @default(0) @map("r_users")
  rLocations       Int       @default(0) @map("r_locations")
  rNests           Int       @default(0) @map("r_nests")
  rEggs            Int       @default(0) @map("r_eggs")
  rDatabaseHosts   Int       @default(0) @map("r_database_hosts")
  rServerDatabases Int       @default(0) @map("r_server_databases")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "api_keys_user_id_foreign")
  @@map("api_keys")
}

// ─── Setting ────────────────────────────────────────────────────────────────

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("settings")
}

// ─── Session ────────────────────────────────────────────────────────────────

model Session {
  id           String  @id
  userId       Int?    @map("user_id")
  ipAddress    String? @map("ip_address")
  userAgent    String? @map("user_agent")
  payload      String 
  lastActivity Int     @map("last_activity")

  @@index([userId], map: "sessions_user_id_index")
  @@index([lastActivity], map: "sessions_last_activity_index")
  @@map("sessions")
}

// ─── UserSSHKey ─────────────────────────────────────────────────────────────

model UserSSHKey {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  name        String   
  fingerprint String   
  publicKey   String    @map("public_key")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "user_ssh_keys_user_id_foreign")
  @@map("user_ssh_keys")
}

// ─── RecoveryToken ──────────────────────────────────────────────────────────

model RecoveryToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String  
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "recovery_tokens_user_id_foreign")
  @@map("recovery_tokens")
}

// ─── Mount ──────────────────────────────────────────────────────────────────

model Mount {
  id            Int     @id @default(autoincrement())
  uuid          String  @unique
  name          String  @unique
  description   String?
  source        String 
  target        String 
  readOnly      Boolean @default(false) @map("read_only")
  userMountable Boolean @default(false) @map("user_mountable")

  mountNodes   MountNode[]
  mountServers MountServer[]
  eggMounts    EggMount[]

  @@map("mounts")
}

// ─── MountNode (pivot) ──────────────────────────────────────────────────────

model MountNode {
  nodeId  Int @map("node_id")
  mountId Int @map("mount_id")

  node  Node  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  mount Mount @relation(fields: [mountId], references: [id], onDelete: Cascade)

  @@id([nodeId, mountId])
  @@map("mount_node")
}

// ─── MountServer (pivot) ────────────────────────────────────────────────────

model MountServer {
  serverId Int @map("server_id")
  mountId  Int @map("mount_id")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  mount  Mount  @relation(fields: [mountId], references: [id], onDelete: Cascade)

  @@id([serverId, mountId])
  @@map("mount_server")
}

// ─── EggMount (pivot) ───────────────────────────────────────────────────────

model EggMount {
  eggId   Int @map("egg_id")
  mountId Int @map("mount_id")

  egg   Egg   @relation(fields: [eggId], references: [id], onDelete: Cascade)
  mount Mount @relation(fields: [mountId], references: [id], onDelete: Cascade)

  @@id([eggId, mountId])
  @@map("egg_mount")
}

// ─── Permission ─────────────────────────────────────────────────────────────

model Permission {
  id         Int    @id @default(autoincrement())
  subuserId  Int    @map("subuser_id")
  permission String

  @@index([subuserId], map: "permissions_subuser_id_foreign")
  @@map("permissions")
}

// ─── Domain ─────────────────────────────────────────────────────────────────

model Domain {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  dnsProvider String   @map("dns_provider")
  dnsConfig   Json     @map("dns_config")
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  serverSubdomains ServerSubdomain[]

  @@index([isActive])
  @@index([isDefault])
  @@map("domains")
}

// ─── ServerSubdomain ────────────────────────────────────────────────────────

model ServerSubdomain {
  id         BigInt   @id @default(autoincrement())
  serverId   Int      @map("server_id")
  domainId   BigInt   @map("domain_id")
  subdomain  String  
  recordType String   @map("record_type")
  dnsRecords Json     @map("dns_records")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([domainId, subdomain])
  @@index([serverId], map: "server_subdomains_server_id_index")
  @@index([isActive])
  @@map("server_subdomains")
}

// ─── ElytraJob ──────────────────────────────────────────────────────────────

model ElytraJob {
  id            BigInt    @id @default(autoincrement())
  uuid          String    @unique
  serverId      Int       @map("server_id")
  userId        Int       @map("user_id")
  jobType       String    @map("job_type")
  jobData       Json      @map("job_data")
  status        String    @default("pending")
  progress      Int       @default(0)
  statusMessage String?   @map("status_message")
  errorMessage  String?   @map("error_message")
  elytraJobId   String?   @map("elytra_job_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  submittedAt   DateTime? @map("submitted_at")
  completedAt   DateTime? @map("completed_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([serverId, status], map: "elytra_jobs_server_id_status_index")
  @@index([serverId, jobType], map: "elytra_jobs_server_id_job_type_index")
  @@index([elytraJobId], map: "elytra_jobs_elytra_job_id_index")
  @@index([status, createdAt], map: "elytra_jobs_status_created_at_index")
  @@map("elytra_jobs")
}

// ─── ServerOperation ────────────────────────────────────────────────────────

model ServerOperation {
  id          BigInt    @id @default(autoincrement())
  operationId String    @unique @map("operation_id")
  serverId    Int       @map("server_id")
  userId      Int       @map("user_id")
  type        String   
  status      String    @default("pending")
  message     String?  
  parameters  Json?
  startedAt   DateTime? @map("started_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([serverId, status, createdAt], map: "server_operations_server_status_created")
  @@index([type, status, createdAt], map: "server_operations_type_status_created")
  @@index([status, createdAt], map: "server_operations_status_created")
  @@index([serverId, status], map: "server_operations_server_status")
  @@index([status, startedAt], map: "server_operations_status_started")
  @@map("server_operations")
}

// ─── TaskLog (legacy) ───────────────────────────────────────────────────────

model TaskLog {
  id        Int       @id @default(autoincrement())
  taskId    Int       @map("task_id")
  runStatus Int       @default(0) @map("run_status")
  runTime   DateTime? @map("run_time")
  response  String    @default("")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([taskId], map: "tasks_log_task_id_index")
  @@map("tasks_log")
}

// ─── Notifications (Laravel default) ────────────────────────────────────────

model Notification {
  id             String    @id
  type           String   
  notifiableType String    @map("notifiable_type")
  notifiableId   BigInt    @map("notifiable_id")
  data           Json
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([notifiableType, notifiableId], map: "notifications_notifiable_type_notifiable_id_index")
  @@map("notifications")
}

// ─── PasswordReset ──────────────────────────────────────────────────────────

model PasswordReset {
  email     String   
  token     String   
  createdAt DateTime? @map("created_at")

  @@id([email, token])
  @@index([email], map: "password_resets_email_index")
  @@map("password_resets")
}

// ─── FailedJob (Laravel queue) ──────────────────────────────────────────────

model FailedJob {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique
  connection String  
  queue      String  
  payload    String  
  exception  String  
  failedAt   DateTime @default(now()) @map("failed_at")

  @@map("failed_jobs")
}

// ─── Job (Laravel queue) ────────────────────────────────────────────────────

model Job {
  id          BigInt @id @default(autoincrement())
  queue       String
  payload     String
  attempts    Int    @default(0)
  reservedAt  Int?   @map("reserved_at")
  availableAt Int    @map("available_at")
  createdAt   Int    @map("created_at")

  @@index([queue], map: "jobs_queue_index")
  @@map("jobs")
}

// ─── APILog (legacy) ────────────────────────────────────────────────────────

model ApiLog {
  id         Int      @id @default(autoincrement())
  authorized Boolean  @default(false)
  error      String? 
  key        String? 
  method     String  
  route      String  
  content    String? 
  userAgent  String   @map("user_agent")
  requestIp  String   @map("request_ip")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("api_logs")
}
